{
  "name": "opencode-gws-multi-account",
  "version": "0.3.3",
  "description": "Multi-account management for the Google Workspace CLI (`gws`). opencode plugin: a `tool.execute.before` hook and auto-registered skill.",
  "keywords": [
    "google-workspace",
    "gws",
    "hooks",
    "multi-account",
    "opencode",
    "opencode-plugin"
  ],
  "homepage": "https://github.com/indentcorp/gws-multi-account",
  "license": "MIT",
  "author": "Jeon Suyeol",
  "repository": {
    "type": "git",
    "url": "https://github.com/indentcorp/gws-multi-account.git",
    "directory": "packages/opencode"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "scripts": {
    "prepublishOnly": "cd ../.. && bun run build"
  },
  "devDependencies": {
    "@gws-multi-account/core": "workspace:*"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.0"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18"
  }
}
