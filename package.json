{
  "name": "gws-multi-account-monorepo",
  "version": "0.3.3",
  "description": "Multi-account management for the Google Workspace CLI (`gws`). Monorepo shipping opencode + TypeClaw npm plugins and a root Claude Code marketplace plugin.",
  "private": true,
  "homepage": "https://github.com/indentcorp/gws-multi-account",
  "license": "MIT",
  "author": "Jeon Suyeol",
  "repository": {
    "type": "git",
    "url": "https://github.com/indentcorp/gws-multi-account.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf packages/*/dist packages/*/skills",
    "build": "bun build.ts",
    "test": "bun run build && bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.19",
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18"
  }
}
